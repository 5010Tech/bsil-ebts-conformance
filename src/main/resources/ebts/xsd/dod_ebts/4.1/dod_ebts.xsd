	<!-- ++++++++++++Caveat  Data Elements ++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++ -->
	<!-- +++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++ -->
	<xs:element name="Caveat" type="dod-ebts:CaveatType" nillable="true">
		<xs:annotation>
			<xs:documentation>An element which allows an EBTS file to be annotated with caveat, usage or handling instructions, disclaimer or general information.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CaveatAdjudicatorPOC" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>Point of Contact information for the individual adjudicating the data to generate caveat information.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CaveatAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	Caveat</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CaveatCategoryCode" type="dod-ebts:CaveatCategoryCodeType">
		<xs:annotation>
			<xs:documentation>A kind of caveat.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CaveatDate" type="nc:DateType">
		<xs:annotation>
			<xs:documentation>A date when the caveat was published.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CaveatOriginatingAgencyID" type="dod-ebts:CaveatOriginatingAgencyIDType">
		<xs:annotation>
			<xs:documentation>An identification for caveat originating agency.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:simpleType name="CaveatOriginatingAgencyIDType">
		<xs:annotation>
			<xs:documentation>Data size stipulations for identification for caveat originating agency</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:length value="9"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:element name="CaveatOriginatingAgencyName" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>A name of the caveat originating agency.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CaveatOriginatingCountryPOC" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>Point of Contact information for the country or agency which originating the caveat.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CaveatReleasability" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>Text describing the release requirements of data transmission</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CaveatSourceReliability" type="dod-ebts:CaveatSourceReliabilitySimpleType">
		<xs:annotation>
			<xs:documentation>A code describing the reliability of the source of the information provided</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:simpleType name="CaveatSourceReliabilitySimpleType">
		<xs:annotation>
			<xs:documentation>Schoolhouse style grading system for caveat relaibility</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:token">
			<xs:enumeration value="A">
				<xs:annotation>
					<xs:documentation>Reliabile - No doubt of authenticity, trustworthiness, or competency; has a history of complete reliability</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="B">
				<xs:annotation>
					<xs:documentation>Usually Reliabile - Minor doubt about authenticity, trustworthiness, or competency; has a history of valid information most of the time</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="C">
				<xs:annotation>
					<xs:documentation>Fairly Reliable - Doubt of authenticity, trustworthiness, or competency but has provided valid information in the past</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="D">
				<xs:annotation>
					<xs:documentation>Not Usually Reliable - Significant doubt about authenticity, trustworthiness, or competency but has provided valid information in the past</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="E">
				<xs:annotation>
					<xs:documentation>Unreliable - Lacking in authenticity, trustworthiness, or competency; has a history of invalid information</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="F">
				<xs:annotation>
					<xs:documentation>Cannot be Judged - No basis exists for evaluating the reliability of the source</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>
	<xs:element name="CaveatContentReliability" type="dod-ebts:CaveatContentReliabilitySimpleType">
		<xs:annotation>
			<xs:documentation>A code describing the reliability of the content of the information provided</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:simpleType name="CaveatContentReliabilitySimpleType">
		<xs:annotation>
			<xs:documentation>The degree of confidence of the information, from 1 to 6, where 1 is highest</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:token">
			<xs:enumeration value="1">
				<xs:annotation>
					<xs:documentation>Confirmed - Confirmed by other independent sources; logical in itself; consistent with other information on the subject</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="2">
				<xs:annotation>
					<xs:documentation>Probably True - Not confirmed; logical in itself; consistent with other information on the subject</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="3">
				<xs:annotation>
					<xs:documentation>Possibly True - Not confirmed; reasonably logical in itself; agrees with other information on the subject</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="4">
				<xs:annotation>
					<xs:documentation>Doubtfully True - Not confirmed; possible but not logical; no other information on the subject</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="5">
				<xs:annotation>
					<xs:documentation>Improbable - Not confirmed; not logical in itself; contradicted by other information on the subject</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="6">
				<xs:annotation>
					<xs:documentation>Cannot Be Judged - No basis exists for evaluating the validity of the information</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>
