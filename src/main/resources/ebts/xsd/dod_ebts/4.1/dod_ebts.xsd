	<xs:import namespace="http://publication.niem.gov/niem/domains/biometrics/4.0/1/" schemaLocation="../../niem/domains/biometrics/4.0/1/biom.xsd"/>
	<xs:import namespace="http://release.niem.gov/niem/domains/jxdm/6.0/" schemaLocation="../../niem/domains/jxdm/6.0/jxdm.xsd"/>
	<xs:import namespace="http://release.niem.gov/niem/proxy/xsd/4.0/" schemaLocation="../../niem/proxy/xsd/4.0/xs.xsd"/>
	<xs:import namespace="http://release.niem.gov/niem/utility/structures/4.0/" schemaLocation="../../niem/utility/structures/4.0/structures.xsd"/>
	<xs:import namespace="http://release.niem.gov/niem/utility/appinfo/4.0/" schemaLocation="../../niem/utility/appinfo/4.0/appinfo.xsd"/>
	<xs:import namespace="http://release.niem.gov/niem/niem-core/4.0/" schemaLocation="../../niem/niem-core/4.0/niem-core.xsd"/>
	<xs:import namespace="http://cjis.fbi.gov/fbi_ebts/10.0" schemaLocation="../../fbi_ebts/10.0/fbi_ebts.xsd"/>
	<xs:import namespace="http://release.niem.gov/niem/codes/fbi_ncic/4.0/" schemaLocation="../../niem/codes/fbi_ncic/4.0/fbi_ncic.xsd"/>
	<xs:import namespace="http://biometrics.nist.gov/standard/2011" schemaLocation="../../itl/2011/itl.xsd"/>
	<xs:import namespace="urn:us:gov:ic:cvenum:genc:country" schemaLocation="../../genc/CVEnumGENCCountryCode.xsd"/>
	<xs:annotation>
		<xs:documentation>The DoD Electronic Biometrics Transmission Specification XML data type complex contents.</xs:documentation>
	</xs:annotation>
	<!--====================================================================================================================================================-->
	<xs:element name="AccessApplicationNumber" type="xs:string">
		<xs:annotation>
			<xs:documentation>The unique identifier for an application to obtain access to a facility or base.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	Access	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessInstallationPermission" type="dod-ebts:AccessInstallationPermissionType">
		<xs:annotation>
			<xs:documentation> Airport Access Installation Permission </xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessInstallationPermissionAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for Access Installation Permission</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocation" type="dod-ebts:AccessLocationType">
		<xs:annotation>
			<xs:documentation>Specifies the location for access. The set consists of the Location Name, Address Value Type, Address Value, Latitude Degree/Minute/Second, Longitude Degree/Minute/Second and Location Description.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	AccessLocation	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationBadge" type="dod-ebts:AccessLocationBadgeType">
		<xs:annotation>
			<xs:documentation> The subject's badge for an access location. The set consists of the badge number, badge color code, badge status code, issue date, expiration date, issuance organization, and issuance office.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationBadgeAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point forAccess Location Badge</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationBadgeColor" type="dod-ebts:AccessLocationBadgeColorType">
		<xs:annotation>
			<xs:documentation>The subject's level of badge color. The set consists of the badge color and the authority approval status code.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationBadgeColorAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for Access Location Badge Color</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationBadgeReplace" type="dod-ebts:AccessLocationBadgeReplaceType">
		<xs:annotation>
			<xs:documentation>The subject's badge replacement information. The set contains the replacement reason code and the badge number that is being replaced.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationBadgeReplaceAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for Access Location Badge Replace</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationExpiration" type="dod-ebts:AccessLocationExpirationType">
		<xs:annotation>
			<xs:documentation>The subject's expiration for the access location. The set is comprised of 2 information items: Access Location Expiration Date and Authority Approval Status Code.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationExpirationAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for Access Location Expiration</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationExpirationDate" type="xs:date">
		<xs:annotation>
			<xs:documentation>The subject's assigned expiration date for the access location.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationFacilityCode" type="dod-ebts:AccessLocationFacilityCodeType">
		<xs:annotation>
			<xs:documentation>The types of facility at an access location.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationFacilityPermission" type="dod-ebts:AccessLocationFacilityPermissionType">
		<xs:annotation>
			<xs:documentation>The subject’s level of facility access. The set consists of the facility type, the force protection condition and the authority approval status code.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationFacilityPermissionAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for Access Location Facility Permission</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationName" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>The name of a geographical location. e.g. Fort Belvoir</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationPrivilege" type="dod-ebts:AccessLocationPrivilegeType">
		<xs:annotation>
			<xs:documentation>The subject’s level of access privileges. The set consists of the privilege  type, the privilege value, the force protection condition and the authority approval status code.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationPrivilegeAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point forAccess Location Badge</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationPrivilegeCode" type="dod-ebts:AccessLocationPrivilegeCodeType">
		<xs:annotation>
			<xs:documentation>The type of privilege allowed at an access location.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationPrivilegeValue" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>The value of the assigned privilege.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationRequiredDay" type="dod-ebts:AccessLocationRequiredDayType">
		<xs:annotation>
			<xs:documentation>Required day of the week for access</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationRequiredDayAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for Access Location Required Day</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationRequiredMonth" type="dod-ebts:AccessLocationRequiredMonthType">
		<xs:annotation>
			<xs:documentation>Required month for access</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AccessLocationRequiredMonthAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	AccessLocationRequiredMonth	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AdditionalResponse" type="dod-ebts:AdditionalResponseType" nillable="true">
		<xs:annotation>
			<xs:documentation>This set of fields shall be used in responses when an additional repository has been searched. It contains information received from the repository that generated an additional response.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AdditionalResponseAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	AdditionalResponse	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AddressAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	Address	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AddressLine1" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>Basic text element for adress</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AddressLine2" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>Basic text element for adress, again</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AFISSegmentControlID" type="xs:string" nillable="true">
		<xs:annotation>
			<xs:documentation>An identifier used by AFIS/FBI to allow tracking of or reference to specific transactions.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AirportInstallationCode" type="dod-ebts:AirportInstallationCodeType">
		<xs:annotation>
			<xs:documentation>The type of airport installation at an access location.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="Alert" type="dod-ebts:AlertType" nillable="true">
		<xs:annotation>
			<xs:documentation>This field contains alert information that will be used in the case where a new submission into the system results in an IDENTED response against the submission containing the alert data</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AlertAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	Alert	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AlertCategoryCode" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>A code to indicate the category assigned to a  subject indicating what action, if any, should be taken regarding the biometric subject if he/she is encountered.</xs:documentation>
			<!-- Data type was dod-ebts:AlertCategoryCodeType -->
		</xs:annotation>
	</xs:element>
	<xs:element name="AlertContactName" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>A name of the agency and individual contact reference responsible for establishing the alert.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AlertDetailDescriptionText" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>A description of the special handling instructions or other information about the individual identified in an alert.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ArrestDateSuffixCode" type="ebts:ArrestDateSuffixCodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>A code representing the sequence of the subject's arrests within a given date and the type of fingerprint card on which the Date of Arrest was contained.</xs:documentation>
			<xs:documentation>Values allowed for external use: L,R, and Y. </xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AssociatedContext" type="biom:AssociatedContextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A kind of set of identifiers pointing to an associated context representation</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AssociatedIndividual" type="dod-ebts:AssociatedIndividualType" nillable="true">
		<xs:annotation>
			<xs:documentation>An element containing the Information of an individual who is associated with the biometric subject.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AssociatedIndividualAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	AssociatedIndividual	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AssociatedIndividualName" type="dod-ebts:PersonNameType" nillable="true">
		<xs:annotation>
			<xs:documentation>A name of the associated individual.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AssociatedIndividualRoleCode" type="dod-ebts:AssociatedIndividualCategoryCodeType">
		<xs:annotation>
			<xs:documentation>A kind of person affiliation with the biometric subject.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AssuranceAuditRevisionID" type="nc:IdentificationType" nillable="true">
		<xs:annotation>
			<xs:documentation>An identification of an audit revision number within the revision history</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AssuranceDateTime" type="nc:DateType" nillable="true">
		<xs:annotation>
			<xs:documentation>A date and time that information assurance data were
            created</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AssuranceOrganization" type="nc:OrganizationType" nillable="true">
		<xs:annotation>
			<xs:documentation>An organization creating information assurance data</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AttentionIndicator" type="nc:TextType" default="UKNOWN">
		<xs:annotation>
			<xs:documentation>This alphanumeric‐special field shall contain a designation of the individual to whose attention a response is to be directed. Periods shall not be used e.g., Det. J. Q. Public shall be entered as DET J Q PUBLIC.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AuthorityApprovalStatusCode" type="dod-ebts:AuthorityApprovalStatusCodeType">
		<xs:annotation>
			<xs:documentation>A data type for a representation of the Authority Approval Status Code</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BadgeClearanceCode" type="dod-ebts:AuthorityApprovalStatusCodeType">
		<xs:annotation>
			<xs:documentation>A data type for a representation of the Authority Approval Status Code or Badge Clearance Code.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BadgeColorCode" type="dod-ebts:BadgeColorCodeType">
		<xs:annotation>
			<xs:documentation>This code specifies the color of the badge assigned to the subject.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BadgeNumber" type="nc:IdentificationType">
		<xs:annotation>
			<xs:documentation>The designated number on the badge.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BadgeReplacementReasonCode" type="dod-ebts:BadgeReplacementReasonCodeType">
		<xs:annotation>
			<xs:documentation>The code indicating the reason the badge is being replaced.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BadgeStatusCode" type="dod-ebts:BadgeStatusCodeType">
		<xs:annotation>
			<xs:documentation>The status of an identification badge, such as valid, replaced, expired.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BATGlobalUniqueID" type="dod-ebts:BATGlobalUniqueIDType" nillable="true">
		<xs:annotation>
			<xs:documentation>An identification containing the Biometrics Automated Toolset (BAT) Global Unique Identifier (GUID) as assigned to the subject by the BAT.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BiometricCollectionUnitAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	BiometricCollectionUnit	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BiometricModality" type="dod-ebts:BiometricModalityType" nillable="true">
		<xs:annotation>
			<xs:documentation>List the biometric modalities available within a specific designated repository and the
identifier assigned to it by the repository if applicable.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BiometricModalityAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	BiometricModality	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BiometricModalityRequestAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	BiometricModalityRequest	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BiometricSubjectContactEmail" type="xs:string" substitutionGroup="nc:ContactMeansAbstract" nillable="true">
		<xs:annotation>
			<xs:documentation>An element for the location of the Biometric Subject Previous (person) residence.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BiometricSubjectPreviousResidence" type="dod-ebts:PersonCurrentResidenceLocationType" nillable="true">
		<xs:annotation>
			<xs:documentation>An element for the location of the Biometric Subject Previous (person) residence.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BiometricSubjectSpecialty" type="dod-ebts:BiometricSubjectSpecialtyType">
		<xs:annotation>
			<xs:documentation>This set of elements describes the specialty and/or skills of the biometric subject, the
proficiency level and the validity of the information provided.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BiometricSubjectSpecialtyAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	BiometricSubjectSpecialty	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BiometricSubjectSpecialtyProficiencyCode" type="dod-ebts:BiometricSubjectSpecialtyProficiencyCodeType">
		<xs:annotation>
			<xs:documentation>The field contains the subject proficeincy level of the specialty and or skills of the biometric subject.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BiometricSubjectSpecialtyValidityCode" type="dod-ebts:PersonInformationValidityCodeType">
		<xs:annotation>
			<xs:documentation>This information item defines the validity of the specialty and or skills of the biometric subject.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="BiometricSubjectSpecialtyValue" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>The specialty and/or skills of the biometric subject. e.g. nuclear explosives, accounting, etc.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CalendarCategoryCode" type="dod-ebts:CalendarCategoryCodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>A code that represents the type of calendar is used when date is specified.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CandidateID" type="xs:string" nillable="true">
		<xs:annotation>
			<xs:documentation>An identification for the Repository Canidate.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CaptureDeviceID" type="nc:IdentificationType" nillable="true">
		<xs:annotation>
			<xs:documentation>An identification of a capture device or source of an image</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CaptureDeviceMakeText" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A make of an image capture device</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CaptureDeviceModelText" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A model of an image capture device</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CaptureResolution" abstract="true" nillable="true">
		<xs:annotation>
			<xs:documentation>A data concept for a minimum or native resolution</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CBEFFImage" type="biom:CBEFFImageType" substitutionGroup="biom:BiometricImageAbstract" nillable="true">
		<xs:annotation>
			<xs:documentation>An image of a CBEFF record</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CollectionCombatantCommandCode" type="dod-ebts:UnitedStatesCOCOMCodeType">
		<xs:annotation>
			<xs:documentation>A code to indicate the category of the US Combatant Command.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CollectedIdentification" type="dod-ebts:CollectedIdentificationType" nillable="true">
		<xs:annotation>
			<xs:documentation>An identification collected from the biometric subject (e.g. passport, social security number, driver license, etc.)</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CollectedIdentificationCode" type="dod-ebts:CollectedIdentificationCodeType">
		<xs:annotation>
			<xs:documentation>The category of the collected identification, such as passport, employee id, and internment serial number.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CollectedIdentificationAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	CollectedIdentification</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CollectionLocationDetail" type="dod-ebts:CollectionLocationDetailType" nillable="true">
		<xs:annotation>
			<xs:documentation>An element that captures the when and where the submission or the Type-2 data were collected.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CollectionLocationDetailAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	CollectionLocationDetail	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="CollectionReasonText" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>An element that captures the purpose for which a biometric sample was obtained from the biometric subject.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ContactTelephone" type="dod-ebts:ContactTelephoneType" nillable="true">
		<xs:annotation>
			<xs:documentation>An element for the telephone by which the person or organization can be contacted by.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ContactTelephoneCategoryCode" type="dod-ebts:ContactTelephoneCategoryCodeType">
		<xs:annotation>
			<xs:documentation>A kind of telephone.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ContextFileFormatAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for ContextFileFormat</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ContextImage" type="dod-ebts:SegmentedImageType" substitutionGroup="biom:BiometricImageAbstract" nillable="true">
		<xs:annotation>
			<xs:documentation>An image of a biometric representing associated context elsewhere in a transaction package</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="Contract" type="dod-ebts:ContractType" nillable="true">
		<xs:annotation>
			<xs:documentation>The set consists of the contract number and the contract expiration date.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ContractAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	Contract	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ContractExpirationDate" type="nc:DateType" nillable="true">
		<xs:annotation>
			<xs:documentation>A date after which the Contract is no longer valid. It may indicate a Contract document should be removed from a registry or index.</xs:documentation>
		</xs:annotation>
	</xs:element>
