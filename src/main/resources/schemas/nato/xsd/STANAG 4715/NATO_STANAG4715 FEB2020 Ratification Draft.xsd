	<xs:element name="PersonDeathEvent" type="nato-4715:PersonDeathEventType" nillable="true">
		<xs:annotation>
			<xs:documentation>The biometric subject's complete date of Death</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="PersonEthnicRacialCharacteristicCode" type="nato-4715:EthnicRacialCharacteristicCodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>A code that represents the ethnic background and/or racial heritage of the person.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="PersonEyeColorAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	PersonEyeColor	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="PersonFifthImportanceName" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A name of a person to represent a the fifth name for a culture using four or five names (e.g., a tribal or village name.) It will be given the ranking of fifth importance of naming in the culture from which the person is associated.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="PersonFourthImportanceName" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A name of a person to represent a the fourth name for a culture using four or five names (e.g., a tribal or village name.) It will be given the ranking of fourth importance of naming in the culture from which the person is associated.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="PersonMeasureValidityCode" type="nato-4715:PersonMeasureValidityCodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>A code that represents the level of validity for the person's measurement provided.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="PersonNameAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	PersonName	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="PersonNameValidityCode" type="nato-4715:NameValidityCodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>A code that represents the the level of validity for the person name provided.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="PersonSexCode" type="nato-4715:PersonSexCodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>An element that represents the larger set of nato-4715 gender codes as a substitution for niem-core element PersonSex.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="PrimaryLanguage" type="nato-4715:PrimaryLanguageType">
		<xs:annotation>
			<xs:documentation>Primary system of words or symbols used for communication by a subject.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="PrimaryLanguageDialect" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>Description of the primary language dialect.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="PrintPositionDescriptors" type="nato-4715:PrintPositionDescriptorsType" nillable="true">
		<xs:annotation>
			<xs:documentation>A description of the probable area of the finger represented in a fingerprint image.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="RecordCategoryCode" type="nato-4715:RecordCategoryCodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>A code that represents the kind of logical record; 00 represents all records.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="RecordDisseminationDate" type="nc:DateType">
		<xs:annotation>
			<xs:documentation>A date a record was disseminated.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="RecordReceivingAgency" type="nc:IdentificationType">
		<xs:annotation>
			<xs:documentation>An agency receiving the transaction record</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="RecordRetentionIndicator" type="nato-4715:RetentionIndicatorType">
		<xs:annotation>
			<xs:documentation>This is a Y/N field indicting whether the information submitted as a part of a transaction is to be retained in the repository.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="RecordTransactionActivity" type="nato-4715:RecordTransactionActivityType" nillable="true">
		<xs:annotation>
			<xs:documentation>A data type to include NATO STANAG Specific information used to identify an Activity that initiated the transaction.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="RecordTransactionCategoryCode" type="nato-4715:TOTCodeType" substitutionGroup="itl:TransactionCategoryAbstract">
		<xs:annotation>
			<xs:documentation>A kind of code used to describe the purpose of the transaction.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ReferenceSystemID" type="xs:string">
		<xs:annotation>
			<xs:documentation>Identifier assigned by the entity. </xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ReferenceSystemIdentifier" type="nato-4715:ReferenceSystemIdentifierType">
		<xs:annotation>
			<xs:documentation> Identifier for an entity.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ReferenceSystemIdentifierAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	ReferenceSystemIdentifier	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="RepositoryAssignedReferenceIdentifier" type="nc:IdentificationType" nillable="true">
		<xs:annotation>
			<xs:documentation>This field contains the numerical designation of the repositories to be searched</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="RepositoryCandidateList" type="nato-4715:RepositoryCandidateListType">
		<xs:annotation>
			<xs:documentation>This field provides a list of candidates that potentially match the submissions biometric images.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="RepositoryCode" type="nato-4715:RepositoryCodeType">
		<xs:annotation>
			<xs:documentation>This field contains the numerical designation of the repositories to be searched. Repository numbers are assigned by the CJIS Division.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="RepositoryReferenceNumber" type="nato-4715:RepositoryReferenceNumberType" nillable="false">
		<xs:annotation>
			<xs:documentation>This field captures the unique reference number for the subject assigned by the NATO's country repository. It consists of 3 information items: Country Code, Designated Repository Code and the Repository Assigned Reference Identifier</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ResponseMaximumCount" type="xs:int" nillable="true">
		<xs:annotation>
			<xs:documentation>This field specifies the maximum number of encounters desired to receive in the response. This number shall not exceed the upper limit set by the repository or the service level agreement. The Application Profile shall document the upper limit allowed.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="RetentionExpirationDate" type="niem-xs:date">
		<xs:annotation>
			<xs:documentation>The date the retention of the transaction shall cease. If retention is to be unlimited, populate it with all 0's (i.e. 00000000).</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="RetentionIndicator" type="nato-4715:RetentionIndicatorType">
		<xs:annotation>
			<xs:documentation>A value of "Y" means retention is acceptable, a value of "N" means the secondary repository should not retain the submission</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ScarsMarksTattoos" type="nato-4715:ScarsMarksTattoosType">
		<xs:annotation>
			<xs:documentation>For each scar, mark, or tattoo present on the biometric subject, the appropriate NCIC code shall be used in this information item that represents the location of the SMT. Blanks are allowed as special characters.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SecondaryLanguage" type="nato-4715:SecondaryLanguageType">
		<xs:annotation>
			<xs:documentation>Description of the Secondary Language.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SecondaryLanguageDialect" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>Description of the Secondary language dialect.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SecondarySearch" type="nato-4715:SecondarySearchType">
		<xs:annotation>
			<xs:documentation>This set of fields, if provided, shall indicate which repository, the transaction type and secondary search retention indicator for a secondary search. Coordination required with Repository to be searched before usage.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SegmentedImageAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for SegmentedImage</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SoftwareName" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A name of a computer application used to process data. eg: Excel</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SoftwareVendorNameText" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A name of a Vendor that made computer software application used to process data. eg: Microsoft</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SoftwareVersionText" type="xs:string" nillable="true">
		<xs:annotation>
			<xs:documentation>A Version Number of a computer application used to process data.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SourceFileFormatAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for Source File Format</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SpeakerIdentificationEngineResponse" type="nato-4715:SpeakerIdentificationEngineResponseType">
		<xs:annotation>
			<xs:documentation>Information set returned with the Speaker Candidate Results (SCR) response TOT as a result of the SID - Speaker Identification request TOT. </xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="StatusDesignator" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>A data concept for a status or condition of something or someone.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SubjectAdvisoryComment" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>The advisory information and comments concerning a biometric subject.</xs:documentation>
			<!--"Derogatory Information" is apparently has policy implications-->
		</xs:annotation>
	</xs:element>
	<xs:element name="TOTCode" type="nato-4715:TOTCodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>Data element representing the type the of transmission, and the type of responses.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TelephoneNumberCategoryCode" type="nato-4715:TelephoneNumberCategoryCode">
		<xs:annotation>
			<xs:documentation>Telephone Number Category Code.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionActionText" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>This field is used to include text answers to submission requests to indicate that a latent case will be established or to indicate recommendations for further actions in either latent or tenprint responses.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionApplicationProfile" type="nato-4715:TransactionApplicationProfileType" nillable="true">
		<xs:annotation>
			<xs:documentation>An application profile specificationfrom ANSI/NIST-ITL 1-2011 update 2013</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionApplicationProfileAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for Transaction Application Profile</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for Transaction</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionCategoryAbstract" abstract="true">
		<xs:annotation>
			<xs:documentation>A data concept for a kind of transaction, as defined by the receiving agency</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionCharacterSetDirectory" type="nato-4715:TransactionCharacterSetType" nillable="true">
		<xs:annotation>
			<xs:documentation>A character set other than 7-bit ASCII used in this transaction</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionCharacterSetAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for Transaction Character Set</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionControlIdentification" type="nc:IdentificationType" nillable="true">
		<xs:annotation>
			<xs:documentation>An identification of a transaction determined by the originating agency</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionControlReferenceIdentification" type="nc:IdentificationType" nillable="true">
		<xs:annotation>
			<xs:documentation>An identification of an original transaction control number (TCN) of a request, used in a transaction response</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionDate" type="nc:DateType" nillable="true">
		<xs:annotation>
			<xs:documentation>A date the transaction was sent by the user</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionDestinationOrganization" type="nc:OrganizationType" nillable="true">
		<xs:annotation>
			<xs:documentation>An organization to which the transaction is being sent</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionDescriptionText" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>This free-text field is used to provide additional information regarding electronic transaction.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionDomain" type="nato-4715:TransactionDomainType" nillable="true">
		<xs:annotation>
			<xs:documentation>A domain for the user-defined Type-02 logical record implementation</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionDomainAugmentationPoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for Transaction Domain</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionDomainName" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A name of the agency, entity, or implementation used for formatting the content of the transaction</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionGeographicNameSetCode" type="nato-4715:TransactionGeographicNameSetCodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>A Geographic name set</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionImageResolutionDetails" type="biom:ImageResolutionType" nillable="true">
		<xs:annotation>
			<xs:documentation>A set of resolution values in pixels per mm for a transaction</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionMajorVersionValue" type="niem-xs:nonNegativeInteger" nillable="true">
		<xs:annotation>
			<xs:documentation>A current major version number of the ANSI/NIST-ITL standard implemented by the software or system creating the file. Always "05" for this version of the standard</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionMinorVersionValue" type="niem-xs:nonNegativeInteger" nillable="true">
		<xs:annotation>
			<xs:documentation>A current minor version number of the ANSI/NIST-ITL standard implemented by the software or system creating the file. Always "00" for this version of the standard</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionOriginatingOrganization" type="nc:OrganizationType" nillable="true">
		<xs:annotation>
			<xs:documentation>An organization originating the transaction</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionPriorityValue" type="niem-xs:nonNegativeInteger" nillable="true">
		<xs:annotation>
			<xs:documentation>An urgency with which transaction response is expected (1 is low, 9 is high)</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionReasonText" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A reason for requesting the transaction</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionSearchResultsCode" type="nato-4715:SRFCodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>An element that indicates the identification results of a biometric search.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionStatusText" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>This free-text field will contain reason, status, or error messages that are generated as a result of the processing of a transaction and will be sent back to the submitter. For example, an Unsolicited Unsolved Latent Delete transaction will contain the reason for the deletion of a record. For native encoding, each message will be separated by the RS separator character..</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionUTCDate" type="nc:DateType" nillable="true">
		<xs:annotation>
			<xs:documentation>A date and time of the transaction in universal Greenwich Mean Time (GMT) units</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransliterationCode" type="nato-4715:TransliterationCodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>A code that represents the language the name was transliterated with the English alphabet.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="Transportation" type="nato-4715:TransportationType" nillable="true">
		<xs:annotation>
			<xs:documentation>An element that describe the method of transportation on which the biometric subject was encountered.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransportCategoryCode" type="nato-4715:TransportCategoryCodeType">
		<xs:annotation>
			<xs:documentation>A code that represents the kind of transport (e.g. Automobile, Aircraft, Train, Animal, etc.)</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransportColorDescriptionText" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A description of the transport device color.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransportIDCategoryCode" type="nato-4715:TransportIDCategoryCodeType" substitutionGroup="nc:IdentificationCategoryAbstract" nillable="true">
		<xs:annotation>
			<xs:documentation>A code that represents the type of identification assigned to the transportation device.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransportIdentification" type="nc:IdentificationType" nillable="true">
		<xs:annotation>
			<xs:documentation>An identification assigned to the transportation device.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransportMakeName" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A name of the manufacturer of the transportation device.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransportModelName" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A name of  the model of the transportation device.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransportModelYear" type="xs:gYear" nillable="true">
		<xs:annotation>
			<xs:documentation>A date in terms of year of the model of the transportation device.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TriggeringEvent" type="nato-4715:TriggeringEventType" nillable="true">
		<xs:annotation>
			<xs:documentation>Something that happens at a given place and time that triggers subsequent collection encounter.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="VendorSoftware" type="nato-4715:VendorSoftwareType" nillable="true">
		<xs:annotation>
			<xs:documentation>Information regarding the software application provided by vendor. The set consists of Software Vendor Name, Software Application Name and Software Application Version Number.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="VoiceEngineRank" type="xs:decimal">
		<xs:annotation>
			<xs:documentation>Rank Score assigned to the voice file submitted as part of the Speaker Identification (SID) TOT.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="WorkingIn" type="iso_3166:CountryAlpha3CodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>A code consistent with the ISO country code that issued the Third Country National Contractor is employed in</xs:documentation>
		</xs:annotation>
	</xs:element>
	<!--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~-->
	<!--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ ToTs Substitutions ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~-->
	<!--~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~-->
	<!-- NDS ~ NATO Deletion Submission -->
	<xs:complexType name="NDSType">
		<xs:annotation>
			<xs:documentation>Transaction for NATO Deletion Submission</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="structures:ObjectType">
				<xs:sequence>
					<xs:element ref="itl:TransactionControlNumberID" minOccurs="1" maxOccurs="1000"/>
					<xs:element ref="nato-4715:RepositoryReferenceNumber" minOccurs="0" maxOccurs="1"/>
					<xs:element ref="nato-4715:TransactionStatusText" minOccurs="0" maxOccurs="1000"/>
					<xs:element ref="nato-4715:RetentionExpirationDate" minOccurs="0" maxOccurs="1000"/>
					<xs:element ref="nato-4715:AttentionIndicator" minOccurs="0" maxOccurs="1"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:element name="NDS" type="nato-4715:NDSType" substitutionGroup="itl:DomainDefinedDescriptiveDetail">
		<xs:annotation>
			<xs:documentation>NDS - NATO Deletion Submission in NIST Biometrics Package</xs:documentation>
		</xs:annotation>
	</xs:element>
	<!-- NDS ~ NATO Deletion Result -->
	<xs:complexType name="NDRType">
		<xs:annotation>
			<xs:documentation>Transaction for NATO Deletion Result</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="structures:ObjectType">
				<xs:sequence>
					<xs:element ref="itl:TransactionControlNumberID" minOccurs="1" maxOccurs="1000"/>
					<xs:element ref="nato-4715:RepositoryReferenceNumber" minOccurs="0" maxOccurs="1"/>
					<xs:element ref="itl:TransactionControlReferenceNumberID" minOccurs="0" maxOccurs="1000"/>
					<xs:element ref="nato-4715:TransactionStatusText" minOccurs="0" maxOccurs="1000"/>
					<xs:element ref="nato-4715:AttentionIndicator" minOccurs="0" maxOccurs="1"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:element name="NDR" type="nato-4715:NDRType" substitutionGroup="itl:DomainDefinedDescriptiveDetail">
		<xs:annotation>
			<xs:documentation>NDS - NATO Deletion Result in NIST Biometrics Package</xs:documentation>
		</xs:annotation>
	</xs:element>
	<!-- NES ~ NATO Enrollment Submission -->
	<xs:complexType name="NESType">
		<xs:annotation>
			<xs:documentation>Transaction for NATO Enrollment Submission</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="structures:ObjectType">
				<xs:sequence>
					<!--SubjectComment used in the enrollment, Advisory Comment used in the response -->
					<!--xs:element ref="nato-4715:SubjectAdvisoryComment" minOccurs="0"/-->
					<xs:element ref="nc:CaseTrackingID" minOccurs="0" maxOccurs="1"/>
					<xs:element ref="nato-4715:BiometricSubjectName" minOccurs="1" maxOccurs="1"/>
					<xs:element ref="nato-4715:BiometricSubjectCurrentResidence" minOccurs="0" maxOccurs="1"/>
					<xs:element ref="nato-4715:BiometricSubjectAlternateName" minOccurs="0" maxOccurs="10"/>
					<xs:element ref="nato-4715:BiometricsSubjectCitizenship" minOccurs="0" maxOccurs="5"/>
					<xs:element ref="nato-4715:PersonBirthEvent" minOccurs="1" maxOccurs="5"/>
					<xs:element ref="nato-4715:BiometricSubjectBirthLocation" minOccurs="1" maxOccurs="1"/>
					<xs:element ref="nato-4715:BiometricSubjectDeathLocation" minOccurs="0" maxOccurs="1"/>
					<xs:element ref="nato-4715:MaritalStatus" minOccurs="0" maxOccurs="1"/>
					<xs:element ref="nato-4715:ContactTelephone" minOccurs="0" maxOccurs="10"/>
