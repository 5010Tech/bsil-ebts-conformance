	<xs:complexType name="AlertType">
		<xs:annotation>
			<xs:documentation>A data type for an Alert.</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="structures:ObjectType">
				<xs:sequence>
					<xs:element ref="nato-4715:AlertCategory"/>
