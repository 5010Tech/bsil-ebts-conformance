	<xs:element name="Alert" type="nato-4715:AlertType" nillable="true">
		<xs:annotation>
			<xs:documentation>This field contains alert information that will be used in the case where a new submission into the system results in an IDENTED response against the submission containing the alert data</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AlertAugmentationpoint" abstract="true">
		<xs:annotation>
			<xs:documentation>An augmentation point for	Alert	</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AlertCategory" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>The category assigned to a  subject indicating what action, if any, should be taken regarding the biometric subject if he/she is encountered.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AlertContactName" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>A name of the agency and individual contact reference responsible for establishing the alert.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AlertDetailDescriptionText" type="nc:TextType">
		<xs:annotation>
			<xs:documentation>A description of the special handling instructions or other information about the individual identified in an alert.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="AlertValue" type="nato-4715:AlertValueSimpleType">
		<xs:annotation>
			<xs:documentation>A code value to indicate an individualk's perceieved threat value.</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="ApplicationProfileVersionIdentification" type="nc:IdentificationType" nillable="true">
		<xs:annotation>
			<xs:documentation>An identification of a version of an application profile specification</xs:documentation>
		</xs:annotation>
	</xs:element>
