	<!-- S -->
	<xs:element name="SignatureImage" type="itl:SignatureImageDataType">
		<xs:annotation>
			<xs:documentation>A representation of a signature</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:complexType name="SignatureImageDataType">
		<xs:annotation>
			<xs:documentation>A type for a representation of the data associated with a signature</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="s:ObjectType">
				<xs:sequence>
					<xs:element ref="biom:ImageHorizontalLineLengthPixelQuantity"/>
					<xs:element ref="biom:ImageVerticalLineLengthPixelQuantity"/>
					<xs:element ref="biom:ScanningResolutionCategoryCode"/>
					<xs:element ref="itl:SignatureCategoryCode"/>
					<xs:element ref="itl:SignatureRepresentationCode"/>
					<xs:choice>
						<xs:element ref="itl:SignatureImageVectorList"/>
						<xs:element ref="nc:Base64BinaryObject"/>
					</xs:choice>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:simpleType name="SignatureCategoryCodeSimpleType">
		<xs:annotation>
			<xs:documentation>A data type for a kind of signature image, i.e. whether an image is the signature of the subject, or the signature of the official processing the transaction</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:integer">
			<xs:enumeration value="0">
				<xs:annotation>
					<xs:documentation>Signature image of the subject</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="1">
				<xs:annotation>
					<xs:documentation>Signature image of the official processing the transaction</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>
	<xs:complexType name="SignatureCategoryCodeType">
		<xs:annotation>
			<xs:documentation>A data type for a kind of signature image, i.e. whether an image is the signature of the subject, or the signature of the official processing the transaction</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="itl:SignatureCategoryCodeSimpleType">
				<xs:attributeGroup ref="s:SimpleObjectAttributeGroup"/>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:complexType name="SignatureImageVectorListType">
		<xs:annotation>
			<xs:documentation>A data type for a list of vectors that describe the pen position in a signature</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="s:ObjectType">
				<xs:sequence>
					<xs:element ref="itl:SignatureImageVector" maxOccurs="unbounded"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="SignatureImageVectorType">
		<xs:annotation>
			<xs:documentation>A data type for a vector that describes the pen position in a signature</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="s:ObjectType">
				<xs:sequence>
					<xs:element ref="itl:VectorPenPressureValue"/>
					<xs:element ref="itl:VectorPositionVerticalCoordinateValue"/>
					<xs:element ref="itl:VectorPositionHorizontalCoordinateValue"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:simpleType name="SignatureRepresentationCodeSimpleType">
		<xs:annotation>
			<xs:documentation>A data type for an indicator whether an image is scanned and not compressed, scanned and compressed, or vector data</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:integer">
			<xs:enumeration value="0">
				<xs:annotation>
					<xs:documentation>Scanned uncompressed</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="1">
				<xs:annotation>
					<xs:documentation>Scanned compressed</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="2">
				<xs:annotation>
					<xs:documentation>Vector</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>
	<xs:complexType name="SignatureRepresentationCodeType">
		<xs:annotation>
			<xs:documentation>A data type for an indicator whether an image is scanned and not compressed, scanned and compressed, or vector data</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="itl:SignatureRepresentationCodeSimpleType">
				<xs:attributeGroup ref="s:SimpleObjectAttributeGroup"/>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:element name="SignatureCategoryCode" type="itl:SignatureCategoryCodeType">
		<xs:annotation>
			<xs:documentation>A kind of signature, indicating whether an image is the signature of the subject, or the signature of the official processing the transaction</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SignatureImageVector" type="itl:SignatureImageVectorType">
		<xs:annotation>
			<xs:documentation>A vector that describes the pen position in a signature</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SignatureImageVectorList" type="itl:SignatureImageVectorListType">
		<xs:annotation>
			<xs:documentation>A list of vectors that describe the pen position in a signature</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="SignatureRepresentationCode" type="itl:SignatureRepresentationCodeType">
		<xs:annotation>
			<xs:documentation>An indicator whether an image is scanned and not compressed, scanned and compressed, or vector data</xs:documentation>
		</xs:annotation>
	</xs:element>
	<!-- T -->
	<xs:element name="Transaction" type="itl:TransactionType">
		<xs:annotation>
			<xs:documentation>An element to represent the transaction meta-data for an ANSI/NIST-ITL transmission</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:complexType name="TransactionType">
		<xs:annotation>
			<xs:documentation>A data type to contain the meta-data for an ANSI/NIST-ITL transmission</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="s:ObjectType">
				<xs:sequence>
					<xs:element ref="itl:TransactionDate"/>
					<xs:element ref="itl:TransactionDestinationAgency"/>
					<xs:element ref="itl:TransactionOriginatingAgency"/>
					<xs:element ref="itl:TransactionUTCDate" minOccurs="0"/>
					<xs:element ref="itl:TransactionControlNumberID"/>
					<xs:element ref="itl:TransactionControlReferenceNumberID" minOccurs="0"/>
					<xs:element ref="itl:TransactionDomain" minOccurs="0"/>
					<xs:element ref="itl:TransactionApplicationProfile" minOccurs="0" maxOccurs="99"/>
					<xs:element ref="itl:TransactionImageResolutionDetails"/>
					<xs:element ref="itl:TransactionMajorVersionValue"/>
					<xs:element ref="itl:TransactionMinorVersionValue"/>
					<xs:element ref="itl:TransactionPriorityValue" minOccurs="0"/>
					<xs:element ref="itl:TransactionCategoryAbstract"/>
					<xs:element ref="itl:TransactionContentSummary"/>
					<xs:element ref="itl:TransactionCharacterSetDirectory" minOccurs="0"/>
					<xs:element ref="itl:TransactionGeographicNameSetCode" minOccurs="0"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:element name="TransactionDestinationAgency" type="itl:TransactionAgencyType">
		<xs:annotation>
			<xs:documentation>The agency to which the transaction is being sent</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionOriginatingAgency" type="itl:TransactionAgencyType">
		<xs:annotation>
			<xs:documentation>The agency which is sending the transaction</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:complexType name="TransactionAgencyType">
		<xs:annotation>
			<xs:documentation>A type for a container for low level agency descriptors</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="s:ObjectType">
				<xs:sequence>
					<xs:element ref="itl:AgencyName" minOccurs="0"/>
					<xs:element ref="nc:IdentificationID"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:element name="TransactionImageResolutionDetails" type="biom:ImageResolutionType" nillable="true">
		<xs:annotation>
			<xs:documentation>A set of resolution values in pixels per mm for a transaction</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionGeographicNameSetCode" type="itl:TransactionGeographicNameSetCodeType" nillable="true">
		<xs:annotation>
			<xs:documentation>A Geographic name set</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:simpleType name="TransactionGeographicNameSetCodeSimpleType">
		<xs:annotation>
			<xs:documentation>A data type for geographic name set</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:token">
			<xs:enumeration value="GENC">
				<xs:annotation>
					<xs:documentation>GENC</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="ISO">
				<xs:annotation>
					<xs:documentation>ISO 3166-1</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>
	<xs:complexType name="TransactionGeographicNameSetCodeType">
		<xs:annotation>
			<xs:documentation>A data type definition for Geographic name set</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:extension base="itl:TransactionGeographicNameSetCodeSimpleType">
				<xs:attributeGroup ref="s:SimpleObjectAttributeGroup"/>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	<xs:element name="TransactionApplicationProfile" type="itl:TransactionApplicationProfileType">
		<xs:annotation>
			<xs:documentation>An application profile specification that is derived from ANSI/NIST-ITL 1-2011update 2015</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:complexType name="TransactionApplicationProfileType">
		<xs:annotation>
			<xs:documentation>A data type for an application profile specification that is derived from ANSI/NIST-ITL 1-2011update 2015</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="s:ObjectType">
				<xs:sequence>
					<xs:element ref="biom:ApplicationProfileOrganizationName"/>
					<xs:element ref="biom:ApplicationProfileName"/>
					<xs:element ref="itl:ApplicationProfileVersionNumberID"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:element name="TransactionCategoryAbstract" abstract="true">
		<xs:annotation>
			<xs:documentation>A data concept for a kind of transaction, as defined by the receiving agency</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionCharacterSetDirectory" type="itl:TransactionCharacterSetType" nillable="true">
		<xs:annotation>
			<xs:documentation>A character set used in this transaction</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:complexType name="TransactionCharacterSetType">
		<xs:annotation>
			<xs:documentation>A data type for a character set used in this transaction</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="s:ObjectType">
				<xs:sequence>
					<xs:choice>
						<xs:sequence>
							<xs:element ref="itl:CharacterSetCommonNameCode"/>
							<xs:element ref="itl:CharacterSetIndexCode"/>
						</xs:sequence>
						<xs:sequence>
							<xs:element ref="itl:CharacterSetUserDefinedName"/>
							<xs:element ref="itl:CharacterSetIndexUserDefinedCode"/>
						</xs:sequence>
					</xs:choice>
					<xs:element ref="itl:CharacterSetVersionID" minOccurs="0"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:element name="TransactionContentSummary" type="itl:TransactionContentSummaryType">
		<xs:annotation>
			<xs:documentation>A summary of the record contents being transmitted</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:complexType name="TransactionContentSummaryType">
		<xs:annotation>
			<xs:documentation>A data type for a summary of the record contents being transmitted</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="s:ObjectType">
				<xs:sequence>
					<xs:element ref="itl:ContentRecordQuantity"/>
					<xs:element ref="itl:ContentRecordSummary" maxOccurs="999"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:element name="TransactionControlNumberID" type="niem-xs:string" nillable="true">
		<xs:annotation>
			<xs:documentation>An identification of a transaction determined by the originating agency</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionControlReferenceNumberID" type="niem-xs:string" nillable="true">
		<xs:annotation>
			<xs:documentation>An identification of an original transaction control number (TCN) of a request, used in a transaction response or resubmission</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionDate" type="niem-xs:date" nillable="true">
		<xs:annotation>
			<xs:documentation>A date the transaction was sent by the user</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionDomain" type="itl:TransactionDomainType" nillable="true">
		<xs:annotation>
			<xs:documentation>A domain for the user-defined Type-02 logical record implementation</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionDomainName" type="nc:TextType" nillable="true">
		<xs:annotation>
			<xs:documentation>A name of the agency, entity, or implementation used for formatting the content of the transaction</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:complexType name="TransactionDomainType">
		<xs:annotation>
			<xs:documentation>A data type for a domain for the user-defined Type-02 logical record implementation</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="s:ObjectType">
				<xs:sequence>
					<xs:element ref="itl:DomainVersionNumberID" minOccurs="0"/>
					<xs:element ref="itl:TransactionDomainName"/>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:element name="TransactionUTCDate" type="niem-xs:dateTime" nillable="true">
		<xs:annotation>
			<xs:documentation>A date and time of the transaction in universal Greenwich Mean Time (GMT) units</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionMajorVersionValue" type="itl:MajorVersionNumberType" nillable="false">
		<xs:annotation>
			<xs:documentation>A current major version number of the ANSI/NIST-ITL standard implemented by the software or system creating the file. </xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionMinorVersionValue" type="itl:MinorVersionNumberType" nillable="true">
		<xs:annotation>
			<xs:documentation>A current minor version number of the ANSI/NIST-ITL standard implemented by the software or system creating the file. </xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:element name="TransactionPriorityValue" type="itl:PriorityValueType">
		<xs:annotation>
			<xs:documentation>An urgency with which transaction response is expected (1 is low, 9 is high)</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:complexType name="TwoCharacterTextType">
		<xs:annotation>
			<xs:documentation>A user-generated text string that is limited to two characters only</xs:documentation>
		</xs:annotation>
		<xs:simpleContent>
			<xs:restriction base="nc:TextType">
				<xs:length value="2"/>
			</xs:restriction>
		</xs:simpleContent>
	</xs:complexType>
